# OffMarketIQ — example env file. Copy to .env and fill in real values.
# Never commit .env. .gitignore enforces this.

# -------- Environment --------
ENVIRONMENT=development                 # development | staging | production
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR

# -------- Database --------
# Inside docker-compose the postgres host is the service name `postgres`.
# Outside (e.g. local CLI scripts), use localhost.
DATABASE_URL=postgresql+asyncpg://offmarketiq:CHANGE_ME@postgres:5432/offmarketiq
# Sync URL used by Alembic + Celery beat scheduler.
DATABASE_URL_SYNC=postgresql+psycopg2://offmarketiq:CHANGE_ME@postgres:5432/offmarketiq
POSTGRES_DB=offmarketiq
POSTGRES_USER=offmarketiq
POSTGRES_PASSWORD=CHANGE_ME

# -------- Redis (Celery broker + result backend) --------
REDIS_URL=redis://redis:6379/0

# -------- App secrets --------
# Used for API-key hashing and HMAC signing on outbound webhooks.
SECRET_KEY=CHANGE_ME_TO_64_CHAR_RANDOM_STRING

# -------- scrape.do --------
# Existing credential — share via 1Password vault. Don't commit.
SCRAPE_DO_API_KEY=

# -------- Anthropic (Vision fallback) --------
# claude-sonnet-4-20250514. Used only as last-resort HTML extractor.
ANTHROPIC_API_KEY=

# -------- SmartyStreets (USPS CASS) --------
SMARTY_AUTH_ID=
SMARTY_AUTH_TOKEN=

# -------- PACER --------
# Bankruptcy filings client. Per CLAUDE.md, NEVER persisted to DB.
PACER_USERNAME=
PACER_PASSWORD=

# -------- Observability (optional) --------
SENTRY_DSN=
PROMETHEUS_PORT=9090
