# Database Configuration
DATABASE_URL=postgresql://aiwholesail:your_secure_password@localhost:5432/aiwholesail
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aiwholesail
DB_USER=aiwholesail
DB_PASSWORD=your_secure_password

# JWT Configuration
JWT_SECRET=your_very_secure_jwt_secret_at_least_32_characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# OpenAI / Anthropic Configuration
OPENAI_API_KEY=sk-your_openai_api_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# SendGrid Email Configuration
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# RapidAPI Configuration
RAPIDAPI_KEY=your_rapidapi_key

# Plivo SMS Configuration
PLIVO_AUTH_ID=your_plivo_auth_id
PLIVO_AUTH_TOKEN=your_plivo_auth_token
PLIVO_PHONE_NUMBER=+1234567890

# Application Configuration
PORT=3202
NODE_ENV=production
FRONTEND_URL=https://aiwholesail.com
API_URL=https://api.aiwholesail.com

# Security
CORS_ORIGINS=https://aiwholesail.com,https://www.aiwholesail.com
