# Database Configuration
DATABASE_URL=postgresql://aiwholesail:your_secure_password@localhost:5432/aiwholesail
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aiwholesail
DB_USER=aiwholesail
DB_PASSWORD=your_secure_password

# JWT Configuration
JWT_SECRET=your_very_secure_jwt_secret_at_least_32_characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# OpenAI / Anthropic Configuration
OPENAI_API_KEY=sk-your_openai_api_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# Resend Email Configuration (emails sent from @aiwholesail.com)
RESEND_API_KEY=re_your_resend_api_key

# RapidAPI Configuration (Zillow Scraper API)
RAPIDAPI_KEY=your_rapidapi_key
ZILLOW_RAPIDAPI_KEY=your_rapidapi_key

# Twilio SMS/Voice Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Application Configuration
PORT=3202
NODE_ENV=production
FRONTEND_URL=https://aiwholesail.com
API_URL=https://api.aiwholesail.com

# Security
CORS_ORIGINS=https://aiwholesail.com,https://www.aiwholesail.com

# AI Agent (Cmd+K) — see docs/runbooks/cmdk-agent.md
# Kill switch: set to literal "false" to short-circuit /api/ai/agent/chat to 503.
AI_AGENT_ENABLED=true

# MCP Server (/mcp) — see docs/runbooks/mcp-server.md
# Static bearer for external MCP clients (Claude Desktop, Cursor, Continue).
# Generate with: openssl rand -base64 32 | tr -d '\n=' | head -c 40
# Without this, /mcp returns 503. Rotate by replacing here + restart aiwholesail-api.
MCP_API_KEY=generate_a_long_random_string

# scrape.do — self-hosted Zillow + TruePeopleSearch scraper
# See docs/runbooks/scrape-do-operations.md
# Without this, every scrape.do call throws ScrapeDoError and the route-layer
# fallback rethrows the original RapidAPI error — i.e. behavior matches pre-#288.
SCRAPE_DO_API_TOKEN=
# Optional: set to 'true' to enable JS-render on TruePeopleSearch fetches (5x cost). Off by default.
# Flip this when TPS block rate climbs (look for TpsScrapeError reason=empty_html in logs).
SCRAPE_DO_TPS_RENDER=

