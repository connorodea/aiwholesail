# bun lockfile — repo standardizes on npm; bun.lockb adds noise
bun.lockb

# macOS Finder duplicate-file artifacts (Cmd+D copies)
# These slip in via syncthing and add bundle noise; reject at git layer.
* 2.*
* 3.*
* copy.*
* copy 2.*

