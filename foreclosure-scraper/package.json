{
  "name": "foreclosure-scraper",
  "version": "0.1.0",
  "private": true,
  "description": "Modular public-record foreclosure data scraper for aiwholesail.com — NOD / LP / NTS / REO collection from county recorders and court dockets.",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "migrate": "ts-node scripts/migrate.ts",
    "backfill": "ts-node scripts/backfill.ts",
    "test-adapter": "ts-node scripts/test-adapter.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' 'scripts/**/*.ts'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "axios": "^1.7.7",
    "bull": "^4.16.5",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "playwright": "^1.48.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
