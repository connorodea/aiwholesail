# PostgreSQL (shares the aiwholesail DB; tables are prefixed/isolated)
DATABASE_URL=postgres://aiwholesail:password@localhost:5432/aiwholesail

# Redis (Bull queue)
REDIS_URL=redis://localhost:6379

# Cloudflare R2 (raw HTML snapshots — audit trail)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=foreclosure-snapshots

# Optional rotating residential proxy (http://user:pass@host:port)
PROXY_URL=

# Worker tuning
QUEUE_CONCURRENCY=3
MAX_PAGES_PER_RUN=50
DEFAULT_RATE_LIMIT_MS=2000

# HTTP server (/health)
PORT=8081

# pino log level (trace|debug|info|warn|error)
LOG_LEVEL=info

# Set true in dev for pino-pretty stdout
LOG_PRETTY=false

# Process role: "all" boots scheduler + worker + http;
# "worker" boots only the queue worker; "scheduler" boots only cron.
# Useful for separating concerns across PM2/systemd units.
PROCESS_ROLE=all
